APP_NAME=AppHubSandbox
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8790

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apphub_sandbox_test
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

APPHUB_API_PREFIX=apphub
APPHUB_DEV_USER_IDS=1
APPHUB_ALLOW_LOCALHOST_API_URLS=true
APPHUB_ALLOWED_HUB_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
APPHUB_ALLOWED_PRODUCT_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
